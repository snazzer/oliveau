<?
$bata_1 = array(
   'title'=>'Problem',
   'data'=>'The project was done in collaboration with the Bata Shoe Museum.  The outreach program 
   director asked us to investigate how the museum could offer an engaging visitor experience to 
   visitors who are blind.  They were evaluating the merits of purchasing audio devices.  As such, 
   we decided to investigate whether existing technologies could be adapted for use.  However, in 
   order to do so, we first had to understand the features of the ideal device.',
   'images'=>array(
     '1'=>'bata/problem.jpg'
   )
);
   
$bata_2 = array(
   'title'=>'The Ethnographic Approach',
   'data'=>'We took an ethnographic approach and conducted participant observation sessions with our 
   participants.  In several instances, the researchers participated as the ‘companion’ of the 
   participant.  By doing this, we were able to observe the difficulties encountered by the participant 
   and also experience the issues faced by companion.  This is critical since much of the literature 
   review indicated that the museum visit is a social experience.  We ended off each session with a 
   debriefing semi-structured interview in order to clarify actions that we did not understand.',
   'images'=>array(
      '1'=>'bata/ethno1.jpg',
      '2'=>'bata/ethno3.jpg',
      '3'=>'bata/ethno4.jpg',
      '4'=>'bata/ethno5.jpg'
   )
);

$bata_3 = array(
   'title'=>'Organizing the Raw Data',
   'data'=>'Qualitative data was analyzed by creating word clouds and affinity diagrams.  This allowed us 
   to see the themes that were common across our participants including: the desire to visit the museum 
   for a social experience, the information structure and content preferences, and device preferences.',
   'images'=>array(
      '1'=>'bata/data1.jpg',
      '2'=>'bata/data2.jpg'
   )
);

$bata_4 = array(
   'title'=>'Wizard-Of-Oz',
   'data' => 'We prototyped a device with the ideal hardware features and information structure by using the 
   Wizard of Oz simulation technique.  Participants were given devices (iPod touch, car remote, and presentation 
   remote) that varied in size and features (number of tactile buttons, touch screen, etc.).  They walked around 
   the gallery searching for information about the space or an artifact as researchers simulated the functionality.',
   'images'=>array(
      '1'=>'bata/wizard1.jpg',
      '2'=>'bata/wizard3.jpg',
      '3'=>'bata/wizard4.jpg',
      '4'=>'bata/wizard5.jpg'
   )
);

$bata_5 = array(
   'title'=>'Recommended Prototype',
   'data'=>'We discovered that the ideal audio device would include the following features:
   <ul>
   <li>A verbal description of the museum layout</li>
   <li>Three-tiered information structure</li>
   <li>Non-linear tour that allowed users to choose exhibits of their interest</li>
   <li>Device that fits in one hand but also has a strap</li>
   <li>A button dedicated to repeating instructions</li>
   <li>A button that controls the speed of speech</li>
   <li>A button that controls the volume of speech</li>
   </ul>
   ',
   'images'=>array(
      '1'=>'bata/prototype.jpg'
   )
);

